{
  "env": {
    "browser": true,
    "es2021": true
  },
  "extends": "eslint:recommended",
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "no-console": ["warn", {"allow": ["warn", "error"]}],
    "no-unused-vars": "off",
    "@typescript-eslint/no-unused-vars": "error"
  }
}
